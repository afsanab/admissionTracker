# ─────────────────────────────────────────────
# CareTrack Backend – Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# Store all production secrets in Azure Key Vault.
# ─────────────────────────────────────────────

# ── Server ──
NODE_ENV=development
PORT=3001

# ── PostgreSQL ──
# Option A — single URL (hosted DB: Supabase, Azure, Render, etc.):
#   postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=

# Option B — local Postgres (leave DATABASE_URL empty and use these):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=caretrack
DB_USER=postgres
DB_PASSWORD=your_local_password
DB_SSL=false
# Strict TLS certificate verification. true = verify provider CA (preferred
# in production). false = accept self-signed (only OK for local Postgres).
DB_SSL_STRICT=false

# ── JWT / sessions ──
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Production: store in Azure Key Vault and reference via Managed Identity.
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12

# ── Session cookie / CSRF ──
COOKIE_NAME=caretrack_session
CSRF_COOKIE_NAME=caretrack_csrf
# In production set to "none" if API and SPA live on different sites
# (also forces Secure). For local same-origin dev keep "lax".
COOKIE_SAMESITE=lax
# Set to your apex domain in production to share session across subdomains.
COOKIE_DOMAIN=

# ── Account lockout ──
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_WINDOW_MIN=15
LOCKOUT_DURATION_MIN=15

# ── CORS ──
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:5173

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Audit Logging (Azure Blob Storage, optional) ──
# In production this enables append-only shipping of audit events to Azure
# Blob Storage with a 7-year immutability policy (HIPAA).
AZURE_STORAGE_CONNECTION_STRING=
AZURE_AUDIT_CONTAINER=caretrack-audit-logs
# Days to keep audit_log rows in Postgres before nightly purge.
AUDIT_LOG_RETENTION_DAYS=90

# ── Scheduled jobs ──
# Set to "false" if running under multiple instances and a single
# external scheduler triggers the work via /api/jobs (TODO).
SCHEDULER_ENABLED=true
# Daily task generation cron (UTC).
TASK_SCHEDULER_CRON=0 5 * * *

# ── Demo seed only (npm run seed — never in production) ──
# All seeded demo accounts share this password. Pick a unique value per machine.
SEED_DEMO_PASSWORD=

# ── Invitations (admin signup links) ──
INVITE_EXPIRES_DAYS=7
APP_PUBLIC_URL=http://localhost:5173
# INVITE_PATH=/?invite=

# ── Invite emails (optional — Resend: https://resend.com) ──
RESEND_API_KEY=
EMAIL_FROM=CareTrack <onboarding@resend.dev>
