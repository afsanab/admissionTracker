# ─────────────────────────────────────────────
# CareTrack Backend – Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# Store all production secrets in Azure Key Vault.
# ─────────────────────────────────────────────

# ── Server ──
NODE_ENV=development
PORT=3001

# ── PostgreSQL (Azure Database for PostgreSQL – Flexible Server) ──
# Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DB_HOST=https://anjuytuznlqsfzoxgery.supabase.co
DB_PORT=5432
DB_NAME=caretrack
DB_USER=caretrackadmin
DB_PASSWORD=RiyadMeem2026!
DB_SSL=true

# ── JWT ──
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Store the production value in Azure Key Vault, not here.
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.azurestaticapps.net

# ── Audit Logging (Azure Blob Storage) ──
# Required in production for HIPAA audit trail.
# Leave blank to fall back to local file logging in development.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_AUDIT_CONTAINER=caretrack-audit-logs

# ── Invitations (admin signup links) ──
# Default validity of new invites
INVITE_EXPIRES_DAYS=7
# Optional: full public URL of the frontend (used in invite links and emails). Required for correct links in production.
APP_PUBLIC_URL=http://localhost:5173
# Path fragment for invite URLs (token is appended). Default: /?invite=
# INVITE_PATH=/?invite=

# ── Invite emails (optional — Resend: https://resend.com) ──
# If set, creating an invitation with an "email" address sends the link automatically.
RESEND_API_KEY=re_cC5E1o7n_7km49aFxML4fgYhQ3ShTUDbG
# Must be a sender Resend verified (e.g. onboarding@resend.dev for testing, or your domain after DNS verify)
EMAIL_FROM=CareTrack <onboarding@resend.dev>

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Bcrypt ──
BCRYPT_ROUNDS=12
