# Frontend production build configuration.
# Copy to `.env.production.local` and set values, OR set these as build-time
# variables in your hosting provider (Azure Static Web Apps, Vercel, etc.).

# Origin of the CareTrack API. NO trailing slash. Required in production:
# without it the SPA will try to call the SWA origin itself.
VITE_API_BASE=https://api.your-domain.example
